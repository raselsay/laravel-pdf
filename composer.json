{
  "name": "rasel/laravel-pdf",
  "description": "Laravel PDF view and download package",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Rasel\\LaravelPdf\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Rasel\\LaravelPdf\\PdfServiceProvider"
      ]
    }
  },
  "require": {
    "php": "^8.1",
    "barryvdh/laravel-dompdf": "^2.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.16",
    "phpunit/phpunit": "^11.5.3"
  }
}
